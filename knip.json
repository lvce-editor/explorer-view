{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["*.js"]
    },
    "packages/build": {
      "project": ["src/**/*.ts"]
    },
    "packages/e2e": {
      "entry": ["src/**/*.ts", "scripts/*.js", "fixtures/**/main.js"],
      "project": ["src/**/*.ts", "scripts/*.js", "fixtures/**/*.js"]
    },
    "packages/explorer-view": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/server": {
      "project": ["src/**/*.js"]
    }
  }
}
