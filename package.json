{
  "name": "@lvce-editor/explorer-view-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "./packages/build/node_modules/.bin/esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/explorer-view/src/explorerViewWorkerMain.ts --outfile=.tmp/dist/dist/explorerViewWorkerMain.js",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:firefox": "cd packages/e2e && npm run e2e:firefox",
    "e2e:firefox:headless": "cd packages/e2e && npm run e2e:firefox:headless",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "measure": "cd packages/build && npm run measure",
    "measure:visible": "cd packages/build && npm run measure:visible",
    "test": "lerna run test",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^15.4.0",
    "@lvce-editor/eslint-plugin-github-actions": "^15.4.0",
    "@lvce-editor/eslint-plugin-regex": "^15.4.0",
    "@lvce-editor/eslint-plugin-tsconfig": "^15.4.0",
    "eslint": "^10.2.0",
    "knip": "^6.25.0",
    "lerna": "^8.2.4",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
