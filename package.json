{
  "name": "@lvce-editor/explorer-view-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "npm exec --workspace=packages/build -- esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/explorer-view/src/explorerViewWorkerMain.ts --outfile=.tmp/dist/dist/explorerViewWorkerMain.js",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "npm run e2e --workspace=packages/e2e",
    "e2e:firefox": "npm run e2e:firefox --workspace=packages/e2e",
    "e2e:firefox:headless": "npm run e2e:firefox:headless --workspace=packages/e2e",
    "e2e:headless": "npm run e2e:headless --workspace=packages/e2e",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "measure": "npm run measure --workspace=packages/build",
    "measure:visible": "npm run measure:visible --workspace=packages/build",
    "test": "npm test --workspaces --if-present",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lvce-editor/eslint-config": "^17.0.3",
    "@lvce-editor/eslint-plugin-github-actions": "^17.0.3",
    "@lvce-editor/eslint-plugin-regex": "^17.0.3",
    "@lvce-editor/eslint-plugin-tsconfig": "^17.0.3",
    "@types/node": "^24.8.0",
    "eslint": "^10.7.0",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
